APP_ENV=dev
DB_URL=sqlite:///the_bot_v5.db

API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=
API_FOOTBALL_KEY_HEADER=x-apisports-key
API_TIMEOUT_SECONDS=20
API_RETRY_ATTEMPTS=3
API_RETRY_BACKOFF_SECONDS=1.5
API_INCLUDE_LINEUPS=true
API_INCLUDE_PLAYERS=false
API_INCLUDE_ODDS=true
API_INCLUDE_STATISTICS=true
MAX_ACTIVE_MATCHES=80
LIVE_FETCH_LIMIT=0

DISCORD_WEBHOOK_REAL=
DISCORD_WEBHOOK_DOC=
DISCORD_WEBHOOK_LOGS=
DISCORD_TIMEOUT_SECONDS=12
DISCORD_RETRY_ATTEMPTS=3
DISCORD_RETRY_BACKOFF_SECONDS=1.5
DISCORD_RATE_LIMIT_COOLDOWN_SECONDS=2.5

PRIMARY_BOOKMAKER_NAME=Betify
FALLBACK_BOOKMAKER_NAME=Bet365
DOCUMENTARY_BOOKMAKER_NAME=Bet365

HEARTBEAT_SECONDS=45
MAX_TICKETS_PER_MATCH=2
MAX_REAL_TICKETS_PER_MATCH=1
ALLOW_DOCUMENTARY_DISPATCH=false
DOCUMENTARY_REQUIRES_EXECUTABLE=true
REQUIRE_EXECUTABLE_FOR_REAL=true
REAL_ONLY_TOP_BETS=false
STORE_RAW_PAYLOADS=true
CSV_EXPORT_PATH=exports

COMPETITION_QUALITY_DEFAULT=0.60
FEED_QUALITY_DEFAULT=0.65
MARKET_QUALITY_DEFAULT=0.65

MIN_EDGE_REAL=0.035
MIN_EDGE_TOP_BET=0.065
MIN_EDGE_DOC=0.050
MAX_CHAOS_REAL=0.78
CORRECT_SCORE_ENABLED=true
CORRECT_SCORE_REAL_ENABLED=false
CORRECT_SCORE_MAX_DOC_CANDIDATES=1

TEAM_TOTALS_ENABLED=true
BTTS_ENABLED=true
RESULT_ENGINE_ENABLED=true
FIRST_HALF_ENABLED=true
OVER_UNDER_ENABLED=true

SKIP_FINISHED_STATUSES=true
DISPATCH_MINUTE_MIN=1
DISPATCH_MINUTE_MAX=92
APISPORTS_KEY=
APISPORTS_BASE_URL=https://v3.football.api-sports.io
APISPORTS_TIMEOUT_SECONDS=20
APISPORTS_DAILY_BUDGET=75000
APISPORTS_MIN_REMAINING_REQUESTS=1000
APISPORTS_CACHE_DIR=data/cache/api_sports
APISPORTS_SNAPSHOT_DIR=data/snapshots/api_sports
APISPORTS_NORMALIZED_DIR=data/normalized/api_sports
APISPORTS_REPLAY_AUDIT_DIR=data/audit/api_sports_replay
APISPORTS_QUALITY_MIN_FIXTURES=1
APISPORTS_QUALITY_MIN_OFFERS=1
APISPORTS_QUALITY_MIN_MAPPED_OFFER_RATIO=0.10
APISPORTS_QUALITY_MAX_REVIEW_OFFER_RATIO=0.50
APISPORTS_QUALITY_MAX_REJECTED_OFFER_RATIO=0.20
APISPORTS_QUALITY_MAX_INVALID_ODDS_RATIO=0.00
APISPORTS_QUALITY_MAX_MISSING_FIXTURE_KEY_RATIO=0.00
APISPORTS_QUALITY_MAX_MISSING_MARKET_KEY_RATIO=0.00
APISPORTS_QUALITY_MAX_DUPLICATE_OFFER_KEY_RATIO=0.00
APISPORTS_PIPELINE_OUTPUT_DIR=data/pipeline/api_sports
APISPORTS_RUN_LEDGER_PATH=data/pipeline/api_sports/run_ledger.jsonl
APISPORTS_RUN_REGISTRY_DEFAULT_LIMIT=20
APISPORTS_AUDIT_BUNDLE_DIR=data/pipeline/api_sports/audit_bundles
APISPORTS_AUDIT_INDEX_PATH=data/pipeline/api_sports/audit_bundles/audit_bundle_index.json
APISPORTS_OPERATOR_REPORT_PATH=data/pipeline/api_sports/operator_report.json
